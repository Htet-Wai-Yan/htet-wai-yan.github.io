---
import { ArrowBigLeft } from "@lucide/astro";
import RootLayout from "./RootLayout.astro";
const { sections } = Astro.props;
---

<RootLayout>
  <div class="flex justify-end">
    <article class="p-8 space-y-6">
      <a href="/" class="btn btn-sm"><ArrowBigLeft class="h-4 w-4" /> Home</a>
      <slot />
      <a href="/" class="btn btn-sm"><ArrowBigLeft class="h-4 w-4" /> Home</a>
    </article>
    <aside
      class="w-sm shrink-0 p-8 sticky top-0 h-screen overflow-y-auto border-s border-base-300 prose prose-a:no-underline prose-a:text-sm"
    >
      <h5>On this page</h5>
      <div class="mt-6 space-y-1">
        {
          sections?.map((sec) => (
            <a href={`#${sec}`} class="block">
              {sec}
            </a>
          ))
        }
      </div>
    </aside>
  </div>
</RootLayout>
