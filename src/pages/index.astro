---
import { NotebookText } from "@lucide/astro";
import RootLayout from "./RootLayout.astro";
import { getCollection } from "astro:content";

const notes = await getCollection("notes");
---

<!-- Below is your "component template." It's just HTML, but with
some magic sprinkled in to help you build great templates. -->
<RootLayout>
  <label class="input w-full">
    <svg
      class="h-[1em] opacity-50"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
    >
      <g
        stroke-linejoin="round"
        stroke-linecap="round"
        stroke-width="2.5"
        fill="none"
        stroke="currentColor"
      >
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.3-4.3"></path>
      </g>
    </svg>
    <input type="search" class="grow" placeholder="Search" />
    <kbd class="kbd kbd-md">Enter</kbd>
  </label>
  <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-4 mt-8">
    {
      notes.map((note) => (
        <a href={`/notes/${note.id}`}>
          <div class="border border-base-300 rounded-sm p-4 h-full bg-base-200 hover:bg-base-100">
            <NotebookText class="h-32 w-30 text-base-300" />
            <span class="text-sm">{note.data.title}</span>
          </div>
        </a>
      ))
    }
  </div>
</RootLayout>
